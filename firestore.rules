rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /appointments/{appointmentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && (request.auth.token.email == "prasenjitkakati91@gmail.com" && request.auth.token.email_verified == true);
    }
  }
}
